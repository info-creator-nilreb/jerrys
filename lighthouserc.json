{
  "ci": {
    "collect": {
      "url": ["http://127.0.0.1:3000/", "http://127.0.0.1:3000/produkte"],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --disable-dev-shm-usage --disable-gpu"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.12 }],
        "categories:accessibility": ["warn", { "minScore": 0.75 }],
        "categories:best-practices": ["warn", { "minScore": 0.55 }],
        "categories:seo": ["warn", { "minScore": 0.62 }]
      }
    }
  }
}
