// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Admin authentication subject (Auth.js Credentials + JWT session).
model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         String    @default("admin")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastLoginAt  DateTime? @map("last_login_at")

  @@map("admin_users")
}

model Manufacturer {
  id        String    @id @default(cuid())
  name      String
  sortOrder Int       @default(0) @map("sort_order")
  products  Product[]

  @@map("manufacturers")
}

model Product {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  subtitle    String?
  /// Rich-Text-HTML (nach Speichern serverseitig bereinigt).
  description String?
  manufacturerId String?     @map("manufacturer_id")
  manufacturer   Manufacturer? @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  productNumber  String?     @map("product_number")

  priceGrossCents Int        @map("price_gross_cents")
  priceNetCents   Int        @map("price_net_cents")
  taxRatePercent  Int        @default(19) @map("tax_rate_percent")
  listPriceGrossCents Int?   @map("list_price_gross_cents")
  listPriceNetCents   Int?   @map("list_price_net_cents")
  lowestPrice30dGrossCents Int? @map("lowest_price_30d_gross_cents")
  lowestPrice30dNetCents   Int? @map("lowest_price_30d_net_cents")

  currency    String         @default("EUR")
  /// Physisches Lager; Abbuchung bei Bestellstatus „shipped“ (versandt).
  stockQuantity    Int       @default(0) @map("stock_quantity")
  /// Für Shop, Warenkorb, Checkout; Abbuchung bei erfolgreicher Zahlung (`paid`).
  availableQuantity Int      @default(0) @map("available_quantity")
  deliveryTimeKey  String?   @map("delivery_time_key")
  restockDays      Int?      @map("restock_days")
  minOrderQty      Int       @default(1) @map("min_order_qty")
  purchaseStep     Int       @default(1) @map("purchase_step")
  maxOrderQty      Int?      @map("max_order_qty")

  isActive    Boolean        @default(true) @map("is_active")
  sortOrder   Int            @default(0) @map("sort_order")
  /// Manuell gepflegte Amazon-Sterne (0–5) und Anzahl; URL zur Produktseite. Kein automatischer Abruf.
  amazonRatingAverage Float?   @map("amazon_rating_average")
  amazonRatingCount   Int?     @map("amazon_rating_count")
  amazonReviewUrl       String?  @map("amazon_review_url")

  /// Kategorie-/Claim-Zeile auf der Produktdetailseite (z. B. „FÜR AUGE & GAUMEN“).
  categoryTag   String?  @map("category_tag")
  isBestseller  Boolean  @default(false) @map("is_bestseller")
  /// Kurzer Klartext unter dem Untertitel (nicht HTML).
  leadText      String?  @map("lead_text")
  dimensionsText String? @map("dimensions_text")
  weightText       String? @map("weight_text")
  materialText     String? @map("material_text")
  featureBullets     String[] @default([]) @map("feature_bullets")

  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  images      ProductImage[]
  cartLines   CartLine[]
  orderItems  OrderItem[]

  @@index([isActive, sortOrder])
  @@map("products")
}

/// Globale Versandkonfiguration (genau eine Zeile, id = default).
model ShopShippingSettings {
  id     String @id
  /// Aktive Lieferländer (ISO-3166-1-alpha-2), Checkout-Auswahl.
  shippingCountryCodes String[] @default(["DE"]) @map("shipping_country_codes")
  /// Brutto-Versandkosten in Cent pro Land, z. B. {"DE":499,"AT":899}
  shippingRatesCentsByCountry Json @default("{}") @map("shipping_rates_cents_by_country")
  /// Ab diesem Warenkorb-Brutto (Cent) entfällt der Versand (optional).
  freeShippingFromSubtotalGrossCents Int? @map("free_shipping_from_subtotal_gross_cents")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("shop_shipping_settings")
}

/// Gäste-Warenkorb; Zuordnung über httpOnly-Cookie `jerrys_cart_id`.
model Cart {
  id           String     @id @default(cuid())
  customerNote String?    @map("customer_note")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  lines        CartLine[]

  @@map("carts")
}

enum OrderPaymentStatus {
  pending
  processing
  succeeded
  failed
  canceled
  refunded
}

/// Versanddienst für Sendungsverfolgung (Admin + E-Mail).
enum ShippingCarrier {
  DHL
  DPD
  UPS
  Hermes
}

/// Fortlaufende Rechnungsnummer (eine Zeile, atomar inkrementieren).
model InvoiceCounter {
  id      Int @id @default(1)
  nextSeq Int @default(1) @map("next_seq")

  @@map("invoice_counter")
}

model Order {
  id                  String      @id @default(cuid())
  orderNumber         String      @unique @map("order_number")
  email               String
  phone               String?     @map("phone")
  paymentMethod       String      @map("payment_method")
  status              String      @default("bestaetigt") @map("status")
  shippingFirstName   String      @map("shipping_first_name")
  shippingLastName    String      @map("shipping_last_name")
  shippingCompany     String?     @map("shipping_company")
  shippingLine1       String      @map("shipping_line1")
  shippingLine2       String?     @map("shipping_line2")
  shippingZip         String      @map("shipping_zip")
  shippingCity        String      @map("shipping_city")
  shippingCountry     String      @default("DE") @map("shipping_country")
  billingFirstName    String      @map("billing_first_name")
  billingLastName     String      @map("billing_last_name")
  billingCompany      String?     @map("billing_company")
  billingLine1        String      @map("billing_line1")
  billingLine2        String?     @map("billing_line2")
  billingZip          String      @map("billing_zip")
  billingCity         String      @map("billing_city")
  billingCountry      String      @default("DE") @map("billing_country")
  customerNote        String?     @map("customer_note")
  subtotalGrossCents  Int         @map("subtotal_gross_cents")
  shippingCents       Int         @default(0) @map("shipping_cents")
  taxAmountCents      Int         @map("tax_amount_cents")
  totalGrossCents     Int         @map("total_gross_cents")
  /// true = EU-27: Katalogpreise inkl. USt.; false = Drittland: Netto, keine ausgewiesene USt.
  vatApplies          Boolean     @default(true) @map("vat_applies")
  shippingCarrier     ShippingCarrier? @map("shipping_carrier")
  trackingNumber      String?     @map("tracking_number")
  invoiceNumber       String?     @unique @map("invoice_number")
  invoiceIssuedAt     DateTime?   @map("invoice_issued_at")
  currency            String      @default("EUR")
  idempotencyKey      String?     @unique @map("idempotency_key")
  createdAt           DateTime    @default(now()) @map("created_at")
  items               OrderItem[]
  emailLogs           EmailLog[]
  statusHistory       OrderStatusHistory[]
  events              OrderEvent[]
  payments            OrderPayment[]

  @@map("orders")
}

model OrderPayment {
  id               String             @id @default(cuid())
  orderId          String             @map("order_id")
  order            Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider         String             @map("provider")
  providerRef      String             @map("provider_ref")
  status           OrderPaymentStatus @map("status")
  amountGrossCents Int                @map("amount_gross_cents")
  currency         String             @default("EUR")
  metadata         Json?              @map("metadata")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  @@index([orderId, createdAt])
  @@map("order_payments")
}

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  eventType String   @map("event_type")
  metadata  Json?    @map("metadata")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId, createdAt])
  @@map("order_events")
}

model OrderStatusHistory {
  id         String   @id @default(cuid())
  orderId    String   @map("order_id")
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus String?  @map("from_status")
  toStatus   String   @map("to_status")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([orderId, createdAt])
  @@map("order_status_history")
}

model EmailLog {
  id           String   @id @default(cuid())
  orderId      String   @map("order_id")
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  emailType    String   @map("email_type")
  toEmail      String   @map("to_email")
  status       String
  providerId   String?  @map("provider_id")
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([orderId, emailType])
  @@map("email_logs")
}

model OrderItem {
  id                     String  @id @default(cuid())
  orderId                String  @map("order_id")
  order                  Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId              String  @map("product_id")
  product                Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  productTitleSnapshot   String  @map("product_title_snapshot")
  unitPriceGrossCents    Int     @map("unit_price_gross_cents")
  taxRatePercentSnapshot Int     @map("tax_rate_percent_snapshot")
  quantity               Int
  lineTotalGrossCents    Int     @map("line_total_gross_cents")
  currency               String  @default("EUR")

  @@index([orderId])
  @@map("order_items")
}

model CartLine {
  id        String   @id @default(cuid())
  cartId    String   @map("cart_id")
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([cartId, productId])
  @@map("cart_lines")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String
  sortOrder Int      @default(0) @map("sort_order")
  isCover   Boolean  @default(false) @map("is_cover")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@map("product_images")
}

/// Manuell gepflegte Amazon-Zitate für den Startseiten-Slider (kein Live-Abruf).
model HomepageAmazonReview {
  id        String   @id @default(cuid())
  quote     String
  rating    Int
  headline  String?
  author    String?
  sourceUrl String?  @map("source_url")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sortOrder])
  @@map("homepage_amazon_reviews")
}

/// Bilder für den Startseiten-Slider (z. B. Instagram-Motive), Upload im Admin.
model HomepageSocialImage {
  id        String   @id @default(cuid())
  url       String
  alt       String
  href      String?
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sortOrder])
  @@map("homepage_social_images")
}
