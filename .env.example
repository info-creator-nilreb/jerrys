# PostgreSQL (lokal oder gehostet, z. B. Supabase → Project Settings → Database)
# Supabase: Projekt darf nicht „pausiert“ sein (Dashboard). Verbindungsarten:
# - Direkt (IPv4): db.PROJECT_REF.supabase.co:5432 (aus „Connection string“ / URI)
# - Session Pooler: aws-….pooler.supabase.com:5432 (empfohlen für lange Node-Verbindungen)
# - Transaction Pooler: Port 6543 + ?pgbouncer=true (Prisma: nur nutzen, wenn ihr wisst, warum)
DATABASE_URL="postgresql://USER:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# Supabase Pooler + Prisma Migrate: Bei P1002 (Advisory Lock Timeout) dieselbe Datenbank per Direktverbindung ansprechen.
# In Supabase: Database → Connection string → URI (Host db.PROJECT_REF.supabase.co, Port 5432, nicht aws-*.pooler).
# Dauerhaft für alle Prisma-CLI-Befehle (migrate, db seed): optional setzen — die Next.js-App nutzt weiter DATABASE_URL.
# DIRECT_DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
# Einmalig nur für eine Migration:
# PRISMA_MIGRATE_DATABASE_URL="postgresql://…" npx prisma migrate deploy

# Optional: TLS-Verifikation steuern (pg + Prisma-Adapter)
# In development ist für typische Remote-Hosts (nicht localhost ohne sslmode) standardmäßig
# relaxiert. Dabei werden SSL-Query-Parameter (z. B. sslmode=require) aus der URL entfernt,
# weil `pg` sie sonst vor unserem ssl.rejectUnauthorized=false anwendet.
# Strikte Prüfung erzwingen: DATABASE_SSL_REJECT_UNAUTHORIZED=true
# Auch in production relaxieren (nur wenn nötig): DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Supabase (Project Settings → API) — für @supabase/ssr Client & Session-Refresh
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""

# Auth.js – z. B. openssl rand -base64 32
AUTH_SECRET=""

# Optional: absolute App-URL in Produktion
# AUTH_URL="https://example.com"

# Öffentliche Shop-URL (Links in Bestell-E-Mails). Fallback: AUTH_URL, sonst VERCEL_URL.
# NEXT_PUBLIC_SITE_URL="https://example.com"

# Optional: Nominatim User-Agent für die Lieferadress-Karte auf /checkout/erfolg (OSMF-Richtlinie).
# Wenn leer: Fallback nutzt NEXT_PUBLIC_SITE_URL oder einen generischen Namen.
# NOMINATIM_USER_AGENT="MeinShop/1.0 (https://example.com)"

# Transaktionale E-Mails — ausschließlich Resend: https://resend.com/docs/send-with-nextjs
# Domain in Resend verifizieren; Absender muss zu dieser Domain passen.
RESEND_API_KEY="re_…"
# Absender mit Apostroph im Namen: RFC2047 statt \"…\" in .env (sonst Backslashes im Header)
MAIL_FROM="=?UTF-8?Q?jerry=27s?= <info@example.com>"

# PayPal (Zahlungsart „PayPal“ → Orders v2 Redirect, wenn Client ID + Secret gesetzt)
# Developer Dashboard → Apps & Credentials → Sandbox oder Live
# PAYPAL_CLIENT_ID="…"
# PAYPAL_CLIENT_SECRET="…"
# PAYPAL_ENV="sandbox"   # oder "live"

# Optional: Seed-Admin (prisma db seed)
# ADMIN_SEED_EMAIL="admin@example.com"
# ADMIN_SEED_PASSWORD="…"

# Playwright E2E (optional; Fallback wie Seed oben)
# E2E_ADMIN_EMAIL="admin@example.com"
# E2E_ADMIN_PASSWORD="change-me-now"
